# ─── Firebase Web App (cliente — NEXT_PUBLIC son seguros para el browser) ─
# Obtén estos valores en: Firebase Console → tu proyecto → ⚙️ → Configuración general → "Tus apps"
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=tu-proyecto.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=tu-proyecto
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=tu-proyecto.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789012
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890

# ─── Firebase Admin SDK (servidor — NUNCA exponer al cliente) ─────────────
# Obtén estos valores en: Firebase Console → ⚙️ → Cuentas de servicio → "Generar nueva clave privada"
FIREBASE_ADMIN_PROJECT_ID=tu-proyecto
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxxx@tu-proyecto.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIEo...\n-----END RSA PRIVATE KEY-----\n"

# ─── Anthropic ────────────────────────────────────────────────────────────
# Obtén tu clave en https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── App ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
