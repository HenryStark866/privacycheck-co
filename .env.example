# ──────────────────────────────────────────────────────────────
# VARIABLES DE ENTORNO — copia este archivo a .env.local
# NUNCA subas .env.local al repositorio (ya está en .gitignore)
# ──────────────────────────────────────────────────────────────

# Firebase (cliente — son públicas, van en NEXT_PUBLIC_)
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSy...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=tu-proyecto.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=tu-proyecto
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=tu-proyecto.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abc123

# Firebase Admin (servidor — NUNCA al cliente)
FIREBASE_ADMIN_PROJECT_ID=tu-proyecto
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxx@tu-proyecto.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...\n-----END PRIVATE KEY-----\n"

# IA — Google Gemini (solo servidor)
# Obtén la clave en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy...

# Cookie de sesión (genera un secreto aleatorio, mínimo 32 chars)
SESSION_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio
