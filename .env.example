# ──────────────────────────────────────────────────────────────
# VARIABLES DE ENTORNO — copia este archivo a .env.local
# NUNCA subas .env.local al repositorio (ya está en .gitignore)
# ──────────────────────────────────────────────────────────────

# Firebase (cliente — son públicas, van en NEXT_PUBLIC_)
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSy...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=tu-proyecto.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=tu-proyecto
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=tu-proyecto.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abc123

# Firebase Admin (servidor — NUNCA al cliente)
FIREBASE_ADMIN_PROJECT_ID=tu-proyecto
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxx@tu-proyecto.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...\n-----END PRIVATE KEY-----\n"

# IA — Google Gemini (solo servidor)
# Obtén la clave en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy...

# IA — Grok / xAI (OPCIONAL, solo servidor). Si se define, el bot de WhatsApp
# usa Grok como motor principal y cae a Gemini si falla. Key en https://console.x.ai
# XAI_MODEL es opcional (por defecto grok-2-latest).
XAI_API_KEY=
XAI_MODEL=grok-2-latest

# Cookie de sesión (genera un secreto aleatorio, mínimo 32 chars)
SESSION_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio

# URL pública de la app (para webhooks y enlaces absolutos)
NEXT_PUBLIC_APP_URL=https://privacycheck-co.vercel.app

# ──────────────────────────────────────────────────────────────
# WhatsApp Gateway (OpenWA / WAHA)
# ──────────────────────────────────────────────────────────────
# REQUISITO DE PRODUCCIÓN: el gateway OpenWA debe correr en un VPS
# accesible públicamente (Railway, Render, Fly.io, DigitalOcean, EC2…).
# OPENWA_API_URL en Vercel debe apuntar a esa URL pública con HTTPS.
#
#   • Local (desarrollo):  http://localhost:2785
#   • VPS (producción):    https://wa-gateway.tudominio.com
#
# Sin un OPENWA_API_URL público y alcanzable, el envío/recepción de
# mensajes de WhatsApp queda inactivo (la app degrada con elegancia).
OPENWA_API_URL=https://wa-gateway.tudominio.com
OPENWA_API_KEY=cambia-esto-por-una-api-key-segura
OPENWA_SESSION_NAME=walle
ADMIN_WHATSAPP_NUMBER=57XXXXXXXXXX
