rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    // Verifica membresía usando la clave compuesta uid_companyId
    function isMember(companyId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/memberships/$(request.auth.uid + '_' + companyId));
    }

    // Obtiene el rol — SOLO llamar después de verificar isMember()
    // para evitar get() sobre doc inexistente
    function myRole(companyId) {
      return get(/databases/$(database)/documents/memberships/$(request.auth.uid + '_' + companyId)).data.role;
    }

    function isAdmin(companyId) {
      return isMember(companyId) && myRole(companyId) == 'administrador';
    }

    function canEdit(companyId) {
      return isMember(companyId) && myRole(companyId) in ['administrador', 'evaluador'];
    }

    // ─── users ───────────────────────────────────────────────────────────
    // Cada usuario solo puede leer/escribir su propio documento.
    // La creación inicial va por Admin SDK (route /api/auth/session).
    match /users/{uid} {
      allow read:   if isAuthenticated() && request.auth.uid == uid;
      allow update: if isAuthenticated() && request.auth.uid == uid
                    && !('uid' in request.resource.data)       // no puede cambiar uid
                    && !('email' in request.resource.data);    // no puede cambiar email
      allow create: if false; // solo Admin SDK
      allow delete: if false;
    }

    // ─── companies ───────────────────────────────────────────────────────
    match /companies/{companyId} {
      // Puede leer si es miembro O si fue el creador (para el momento justo
      // después de crear la empresa, antes de que llegue la membresía del server)
      allow read: if isAuthenticated() &&
        (isMember(companyId) || resource.data.createdBy == request.auth.uid);
      // La creación siempre va por la API /api/companies (Admin SDK), pero
      // dejamos la regla como fallback seguro
      allow create: if isAuthenticated() &&
        request.resource.data.createdBy == request.auth.uid;
      allow update: if isAdmin(companyId);
      allow delete: if isAdmin(companyId);
    }

    // ─── memberships ─────────────────────────────────────────────────────
    // Clave compuesta: {uid}_{companyId}
    match /memberships/{membershipId} {
      // El usuario puede leer sus propias membresías
      allow read: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
      // Listado: todas las queries usan Admin SDK — el cliente no necesita listar
      allow list: if false;
      // Escritura solo vía Admin SDK (servidor) — no se permite desde cliente
      // excepto que el usuario se cree su propia membresía inicial
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      allow update: if false; // Solo el servidor puede modificar roles
      allow delete: if isAdmin(resource.data.companyId);
    }

    // ─── evaluations ─────────────────────────────────────────────────────
    match /evaluations/{evaluationId} {
      allow read: if isMember(resource.data.companyId);
      allow create: if canEdit(request.resource.data.companyId);
      allow update: if canEdit(resource.data.companyId);
      allow delete: if isAdmin(resource.data.companyId);

      // ─── answers ─────────────────────────────────────────────────────
      match /answers/{answerId} {
        allow read: if isMember(
          get(/databases/$(database)/documents/evaluations/$(evaluationId)).data.companyId
        );
        allow write: if canEdit(
          get(/databases/$(database)/documents/evaluations/$(evaluationId)).data.companyId
        );
      }

      // ─── recommendations ─────────────────────────────────────────────
      match /recommendations/{recId} {
        allow read: if isMember(
          get(/databases/$(database)/documents/evaluations/$(evaluationId)).data.companyId
        );
        allow write: if isMember(
          get(/databases/$(database)/documents/evaluations/$(evaluationId)).data.companyId
        );
      }
    }

    // ─── Bloquear todo lo demás ───────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
